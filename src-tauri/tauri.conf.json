{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dev Flow Browser",
  "version": "0.1.0",
  "identifier": "local.dev-flow-browser",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx vite --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npx tsc && npx vite build"
  },
  "app": {
    "windows": [
      {
        "title": "Dev Flow Browser",
        "label": "main",
        "width": 1180,
        "height": 760,
        "minWidth": 880,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": []
  }
}
